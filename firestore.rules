rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow create: if request.auth != null && request.resource.data.hostUid == request.auth.uid;
      allow get, update, delete: if request.auth != null && resource.data.hostUid == request.auth.uid;

      match /players/{playerId} {
        allow get: if true;
        allow list, create, update, delete: if request.auth != null && get(/databases/$(database)/documents/games/$(gameId)).data.hostUid == request.auth.uid;
      }
    }
  }
}
